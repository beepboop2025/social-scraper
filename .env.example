# Twitter Configuration
# ---------------------
TWITTER_ENABLED=true
TWITTER_COOKIES_PATH=cookies.json
# For login (optional if cookies exist):
TWITTER_USERNAME=your_username
TWITTER_EMAIL=your_email
TWITTER_PASSWORD=your_password

# Telegram Configuration
# ----------------------
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=your_bot_token_here
# For MTProto (user API) - get from https://my.telegram.org
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here
TELEGRAM_PHONE_NUMBER=+1234567890
TELEGRAM_SESSION_NAME=telegram_scraper

# Scraping Settings
# -----------------
OUTPUT_DIRECTORY=./data
MEDIA_DIRECTORY=./media
OUTPUT_FORMAT=both
SAVE_MEDIA=false
BATCH_SIZE=100
RATE_LIMIT_DELAY=1.0
INCLUDE_REPLIES=false
INCLUDE_RETWEETS=true

# News Sources
# ------------
TELEGRAM_CHANNELS=@bbcnews,@cnn,@reuters_world
TWITTER_QUERIES=breaking news,world news,tech news
NEWS_KEYWORDS=breaking,urgent,announcement,update
