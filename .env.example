# ══════════════════════════════════════════════════════════════
# EconScraper v4.0 — Environment Config
# Copy to .env and fill in your values
# ══════════════════════════════════════════════════════════════

# ── Database (TimescaleDB + pgvector) ──────────────────────
POSTGRES_USER=scraper
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_DB=econscraper
DATABASE_URL=postgresql://scraper:changeme_in_production@localhost:5432/econscraper

# ── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Kafka ──────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── MinIO (raw data storage) ──────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=econscraper
MINIO_SECRET_KEY=econscraper123

# ── Tor Proxy (dark web scraping) ─────────────────────────
TOR_PROXY=socks5://127.0.0.1:9050

# ── LLM / AI ──────────────────────────────────────────────
ANTHROPIC_API_KEY=
OLLAMA_URL=http://localhost:11434

# ── Destination: DragonScope ──────────────────────────────
DRAGONSCOPE_REDIS_URL=redis://localhost:6379/1
DRAGONSCOPE_API_URL=http://localhost:3456

# ── Destination: LiquiFi ──────────────────────────────────
LIQUIFI_REDIS_URL=redis://localhost:6379/2
LIQUIFI_API_URL=http://localhost:8001

# ══════════════════════════════════════════════════════════════
# COLLECTOR API KEYS
# ══════════════════════════════════════════════════════════════

# ── FRED (Federal Reserve Economic Data) ──────────────────
FRED_API_KEY=

# ── data.gov.in ───────────────────────────────────────────
DATA_GOV_API_KEY=

# ── Twitter (cookie-based) ────────────────────────────────
TWITTER_COOKIES_PATH=cookies.json
TWITTER_QUERIES=stock market,crypto,RBI,treasury,forex,defi

# ── Telegram ──────────────────────────────────────────────
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALERT_CHAT_ID=

# ── Reddit (works without auth, higher limits with) ──────
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# ── YouTube Data API v3 ──────────────────────────────────
YOUTUBE_API_KEY=

# ── GitHub (higher rate limits with token) ────────────────
GITHUB_TOKEN=

# ── Discord Bot ──────────────────────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_CHANNELS=

# ── Mastodon (public API works without auth) ──────────────
MASTODON_ACCESS_TOKEN=

# ══════════════════════════════════════════════════════════════
# NO API KEY NEEDED:
# - Hacker News, RSS feeds, Web scraping, SEC EDGAR,
#   Central Banks (RBI/Fed/ECB), Dark web (needs Tor proxy),
#   BSE, NSE, SEBI, CCIL/FBIL rates, World Bank, IMF
# ══════════════════════════════════════════════════════════════
