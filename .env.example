# ══════════════════════════════════════════════════════════════
# Social Scraper Intelligence Platform v3.0 — Environment Config
# Copy to .env and fill in your values
# ══════════════════════════════════════════════════════════════

# ── Database ─────────────────────────────────────────────────
POSTGRES_USER=scraper
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_DB=social_scraper
DATABASE_URL=postgresql://scraper:changeme_in_production@localhost:5432/social_scraper

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Kafka ────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── Tor Proxy (for dark web scraping) ────────────────────────
TOR_PROXY=socks5://127.0.0.1:9050

# ── Destination: DragonScope ─────────────────────────────────
DRAGONSCOPE_REDIS_URL=redis://localhost:6379/1
DRAGONSCOPE_API_URL=http://localhost:3456

# ── Destination: LiquiFi ─────────────────────────────────────
LIQUIFI_REDIS_URL=redis://localhost:6379/2
LIQUIFI_API_URL=http://localhost:8001

# ══════════════════════════════════════════════════════════════
# SCRAPER API KEYS
# ══════════════════════════════════════════════════════════════

# ── Twitter (cookie-based, no API key needed) ────────────────
TWITTER_ENABLED=true
TWITTER_COOKIES_PATH=cookies.json
TWITTER_USERNAME=your_username
TWITTER_EMAIL=your_email
TWITTER_PASSWORD=your_password
TWITTER_QUERIES=stock market,crypto,RBI,treasury,forex,defi,bitcoin,ethereum

# ── Telegram ─────────────────────────────────────────────────
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here
TELEGRAM_PHONE_NUMBER=+1234567890
TELEGRAM_SESSION_NAME=telegram_scraper
TELEGRAM_CHANNELS=@bbcnews,@cnn,@reuters_world

# ── Reddit (optional — works without auth) ───────────────────
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# ── YouTube Data API v3 ──────────────────────────────────────
YOUTUBE_API_KEY=

# ── GitHub (optional — higher rate limits with token) ────────
GITHUB_TOKEN=

# ── Discord Bot ──────────────────────────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_CHANNELS=

# ── Mastodon (optional — public API works without auth) ──────
MASTODON_ACCESS_TOKEN=

# ── Scraping Settings ────────────────────────────────────────
OUTPUT_DIRECTORY=./data
MEDIA_DIRECTORY=./media
OUTPUT_FORMAT=both
SAVE_MEDIA=false
BATCH_SIZE=100
RATE_LIMIT_DELAY=1.0
INCLUDE_REPLIES=false
INCLUDE_RETWEETS=true
NEWS_KEYWORDS=breaking,urgent,announcement,update

# ══════════════════════════════════════════════════════════════
# NO API KEY NEEDED (work out of the box):
# - Hacker News, RSS feeds, Web scraping, SEC EDGAR,
#   Central Banks (RBI/Fed/ECB), Dark web (needs Tor proxy)
# ══════════════════════════════════════════════════════════════
