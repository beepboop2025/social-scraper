# ══════════════════════════════════════════════════════════════
# EconScraper v4.1 — Environment Config
# Copy to .env and fill in your values
#
# TIP: Use the API Key Manager to auto-discover and validate keys:
#   python -m apikeys status     # see what's missing
#   python -m apikeys plan       # prioritized setup guide
#   python -m apikeys quickstart # instant-signup APIs
# ══════════════════════════════════════════════════════════════

# ── Database (TimescaleDB + pgvector) ──────────────────────
POSTGRES_USER=scraper
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_DB=econscraper
DATABASE_URL=postgresql://scraper:changeme_in_production@localhost:5432/econscraper

# ── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Kafka ──────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── MinIO (raw data storage) ──────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=econscraper
MINIO_SECRET_KEY=econscraper123

# ── Tor Proxy (dark web scraping) ─────────────────────────
TOR_PROXY=socks5://127.0.0.1:9050

# ── LLM / AI ──────────────────────────────────────────────
ANTHROPIC_API_KEY=
OLLAMA_URL=http://localhost:11434

# ── Destination: DragonScope ──────────────────────────────
DRAGONSCOPE_REDIS_URL=redis://localhost:6379/1
DRAGONSCOPE_API_URL=http://localhost:3456

# ── Destination: LiquiFi ──────────────────────────────────
LIQUIFI_REDIS_URL=redis://localhost:6379/2
LIQUIFI_API_URL=http://localhost:8001

# ══════════════════════════════════════════════════════════════
# COLLECTOR API KEYS — HIGH PRIORITY (instant signup)
# ══════════════════════════════════════════════════════════════

# ── FRED (120 req/min, instant signup) ────────────────────
# https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# ── data.gov.in (unlimited, instant signup) ───────────────
# https://data.gov.in/user/register
DATA_GOV_API_KEY=

# ── Finnhub (60 req/min, real-time stocks, instant) ──────
# https://finnhub.io/register
FINNHUB_API_KEY=

# ── NewsAPI.org (100 req/day, instant signup) ─────────────
# https://newsapi.org/register
NEWSAPI_KEY=

# ══════════════════════════════════════════════════════════════
# COLLECTOR API KEYS — MEDIUM PRIORITY
# ══════════════════════════════════════════════════════════════

# ── Alpha Vantage (25 req/day, instant signup) ────────────
# https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# ── Polygon.io (5 req/min, instant signup) ────────────────
# https://polygon.io/dashboard/signup
POLYGON_API_KEY=

# ── NewsData.io (200 credits/day, instant) ────────────────
# https://newsdata.io/register
NEWSDATA_API_KEY=

# ── GNews (100 req/day, instant) ──────────────────────────
# https://gnews.io/register
GNEWS_API_KEY=

# ── CoinGecko Demo Key (doubles rate limits) ─────────────
# https://www.coingecko.com/en/api/pricing
COINGECKO_API_KEY=

# ── ExchangeRate-API (1500 req/month, instant) ────────────
# https://www.exchangerate-api.com/
EXCHANGERATE_API_KEY=

# ── Nasdaq Data Link / Quandl (300 req/10s, instant) ─────
# https://data.nasdaq.com/sign-up
NASDAQ_DATA_LINK_API_KEY=

# ══════════════════════════════════════════════════════════════
# SOCIAL PLATFORM KEYS (manual setup, 5 min each)
# ══════════════════════════════════════════════════════════════

# ── Twitter (cookie-based) ────────────────────────────────
TWITTER_COOKIES_PATH=cookies.json
TWITTER_QUERIES=stock market,crypto,RBI,treasury,forex,defi

# ── Telegram ──────────────────────────────────────────────
# Bot: message @BotFather  |  API: https://my.telegram.org/apps
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALERT_CHAT_ID=

# ── Reddit (https://www.reddit.com/prefs/apps) ───────────
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# ── YouTube (https://console.cloud.google.com) ────────────
YOUTUBE_API_KEY=

# ── GitHub (https://github.com/settings/tokens) ──────────
GITHUB_TOKEN=

# ── Discord (https://discord.com/developers/applications) ─
DISCORD_BOT_TOKEN=
DISCORD_CHANNELS=

# ── Mastodon (public API works without auth) ──────────────
MASTODON_ACCESS_TOKEN=

# ── OpenWeatherMap (weather for commodity analysis) ───────
# https://home.openweathermap.org/users/sign_up
OPENWEATHER_API_KEY=

# ── World News API (500 req/month) ────────────────────────
# https://worldnewsapi.com/register
WORLDNEWS_API_KEY=

# ══════════════════════════════════════════════════════════════
# NO API KEY NEEDED (14 sources work out of the box):
# - Hacker News, RSS feeds (14 feeds), Web scraping, SEC EDGAR,
#   Central Banks (RBI/Fed/ECB), Dark web (needs Tor proxy),
#   BSE, NSE, SEBI, CCIL/FBIL rates, World Bank, IMF,
#   Reddit (.json), CoinGecko (basic), arXiv
# ══════════════════════════════════════════════════════════════
